---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Our Farmstand"
  description="Sweet Bites by Laura Farmstand — coming soon!"
>

  <section class="farmstand-hero">
    <div class="container container--narrow">
      <div class="coming-soon-badge">Coming Soon</div>
      <h1>Our Farmstand</h1>
      <p class="lead">
        Something exciting is growing here. Check back soon for fresh seasonal 
        offerings straight from the farmstand — homemade jams, seasonal produce, 
        and more from Laura's kitchen and garden.
      </p>
      <div class="notify-box">
        <p>Want to be the first to know when we launch?</p>
        <a
          href="https://www.facebook.com/profile.php?id=61571575571290"
          target="_blank"
          rel="noopener"
          class="btn btn--primary"
        >
          Follow Us on Facebook
        </a>
      </div>
    </div>
  </section>

  <!-- Blurred preview overlay to hint at future content -->
  <section class="farmstand-preview">
    <div class="container">
      <div class="preview-grid">
        <div class="preview-card">
          <div class="preview-card__icon">🍓</div>
          <h3>Seasonal Preserves</h3>
          <p>Homemade jams and jellies made from fresh seasonal fruit.</p>
        </div>
        <div class="preview-card">
          <div class="preview-card__icon">🌿</div>
          <h3>Garden Fresh</h3>
          <p>Fresh herbs, vegetables, and seasonal produce.</p>
        </div>
        <div class="preview-card">
          <div class="preview-card__icon">🍯</div>
          <h3>Local Honey</h3>
          <p>Pure, raw local honey sourced from nearby beekeepers.</p>
        </div>
        <div class="preview-card">
          <div class="preview-card__icon">🥚</div>
          <h3>Farm Eggs</h3>
          <p>Fresh eggs from happy, well-cared-for hens.</p>
        </div>
      </div>
      <div class="coming-soon-overlay">
        <span>Coming Soon</span>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .farmstand-hero {
    background: var(--color-warm-white);
    padding-block: var(--space-xl);
    text-align: center;
    min-height: 60vh;
    display: flex;
    align-items: center;
  }
  .farmstand-hero .container {
    width: 100%;
  }
  .coming-soon-badge {
    display: inline-block;
    background: var(--color-caramel);
    color: white;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.35rem 1rem;
    border-radius: 20px;
    margin-bottom: var(--space-md);
  }
  .farmstand-hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: var(--space-sm);
  }
  .farmstand-hero .lead {
    font-size: 1.2rem;
    color: var(--color-chocolate);
    opacity: 0.8;
    max-width: 560px;
    margin-inline: auto;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }
  .notify-box {
    background: var(--color-cream);
    border-radius: 8px;
    padding: var(--space-md) var(--space-lg);
    display: inline-block;
  }
  .notify-box p {
    font-weight: 600;
    color: var(--color-chocolate-dark);
    margin-bottom: var(--space-sm);
  }

  .farmstand-preview {
    background: var(--color-cream);
    padding-block: var(--space-xl);
  }
  .farmstand-preview .container {
    position: relative;
  }
  .preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-md);
    filter: blur(4px);
    pointer-events: none;
    user-select: none;
  }
  .preview-card {
    background: white;
    border-radius: 8px;
    padding: var(--space-md);
    text-align: center;
    box-shadow: 0 2px 8px rgba(74,55,40,0.08);
  }
  .preview-card__icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-sm);
  }
  .preview-card h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-xs);
  }
  .preview-card p {
    font-size: 0.9rem;
    color: var(--color-chocolate);
    opacity: 0.8;
  }
  .coming-soon-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }
  .coming-soon-overlay span {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--color-chocolate-dark);
    opacity: 0.5;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>
