---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Sweet Bites by Laura to place a custom order or ask a question."
>

  <section class="contact-hero">
    <div class="container container--narrow">
      <h1>Get in Touch</h1>
      <p class="lead">
        Ready to place an order or have a question? Fill out the form below 
        and Laura will get back to you within 1–2 business days.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-grid">

      <div class="contact-info">
        <h2>Order Info</h2>
        <p>Custom orders are welcome for all occasions. A few things to keep in mind:</p>
        <ul>
          <li>Please allow <strong>3–5 days</strong> notice for most orders</li>
          <li>Heavily decorated cookie orders may need <strong>1–2 weeks</strong></li>
          <li>Large event orders (50+ pieces) should be placed at least <strong>2 weeks ahead</strong></li>
        </ul>

        <div class="contact-social">
          <p>You can also reach Laura on Facebook:</p>
          <a
            href="https://www.facebook.com/profile.php?id=61571575571290"
            target="_blank"
            rel="noopener"
            class="btn btn--facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.413c0-3.026 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.265h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
            Message on Facebook
          </a>
        </div>
      </div>

      <div class="contact-form-wrap">
        <form
          action="https://formspree.io/f/mwvypbbg"
          method="POST"
          class="contact-form"
        >
          <div class="form-group">
            <label for="name">Your Name</label>
            <input type="text" id="name" name="name" required placeholder="Jane Smith" />
          </div>

          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="jane@example.com" />
          </div>

          <div class="form-group">
            <label for="phone">Phone Number (optional)</label>
            <input type="tel" id="phone" name="phone" placeholder="(555) 123-4567" />
          </div>

          <div class="form-group">
            <label for="occasion">Occasion</label>
            <select id="occasion" name="occasion">
              <option value="">Select an occasion...</option>
              <option>Birthday</option>
              <option>Wedding / Shower</option>
              <option>Holiday</option>
              <option>Corporate / Event</option>
              <option>Just Because</option>
              <option>Other</option>
            </select>
          </div>

          <div class="form-group">
            <label for="message">Tell Me About Your Order</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              placeholder="What would you like? How many? Any special colors, themes, or dietary needs?"
            ></textarea>
          </div>

          <button type="submit" class="btn btn--primary btn--full">Send Message</button>
        </form>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .contact-hero {
    background: var(--color-warm-white);
    padding-block: var(--space-xl);
    text-align: center;
  }
  .contact-hero h1 {
    margin-bottom: var(--space-sm);
  }
  .contact-hero .lead {
    font-size: 1.15rem;
    color: var(--color-chocolate);
    opacity: 0.8;
    max-width: 500px;
    margin-inline: auto;
  }

  .contact-body {
    background: var(--color-cream);
    padding-block: var(--space-xl);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-xl);
    align-items: start;
  }
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  .contact-info h2 {
    margin-bottom: var(--space-sm);
  }
  .contact-info p {
    color: var(--color-chocolate);
    opacity: 0.8;
    margin-bottom: var(--space-sm);
  }
  .contact-info ul {
    padding-left: 1.25rem;
    margin-bottom: var(--space-lg);
  }
  .contact-info li {
    color: var(--color-chocolate);
    opacity: 0.8;
    margin-bottom: var(--space-xs);
    line-height: 1.6;
  }
  .contact-social p {
    font-weight: 600;
    color: var(--color-chocolate-dark);
    margin-bottom: var(--space-sm);
  }
  .btn--facebook {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #1877F2;
    color: white;
    padding: 0.65rem 1.25rem;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn--facebook:hover {
    background: #1565d8;
  }

  .contact-form-wrap {
    background: white;
    border-radius: 8px;
    padding: var(--space-lg);
    box-shadow: 0 2px 16px rgba(74,55,40,0.08);
  }
  .form-group {
    margin-bottom: var(--space-md);
  }
  .form-group label {
    display: block;
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-chocolate-dark);
    margin-bottom: 0.4rem;
  }
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.65rem 0.875rem;
    border: 1.5px solid rgba(74,55,40,0.2);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-chocolate-dark);
    background: var(--color-warm-white);
    transition: border-color 0.2s;
    box-sizing: border-box;
  }
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-caramel);
  }
  .form-group textarea {
    resize: vertical;
  }
  .btn--full {
    width: 100%;
    justify-content: center;
  }
</style>
