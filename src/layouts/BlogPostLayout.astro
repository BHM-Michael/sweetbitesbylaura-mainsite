---
/**
 * BlogPostLayout.astro
 * Use this as the layout for all MDX blog posts.
 *
 * In your .mdx frontmatter:
 *   layout: ../../layouts/BlogPostLayout.astro
 */
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pubDate: string;
    modifiedDate?: string;
    tags?: string[];
    heroImage?: string;
    author?: string;
  };
}

const { frontmatter } = Astro.props;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  seoType="article"
  publishDate={new Date(frontmatter.pubDate).toISOString()}
  modifiedDate={frontmatter.modifiedDate ? new Date(frontmatter.modifiedDate).toISOString() : undefined}
  tags={frontmatter.tags}
  image={frontmatter.heroImage}
>
  <article class="blog-post">
    <header class="blog-post__header">
      <div class="container container--narrow">
        {frontmatter.tags && (
          <div class="blog-post__tags">
            {frontmatter.tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        <h1>{frontmatter.title}</h1>
        <p class="blog-post__meta">
          By {frontmatter.author ?? "Laura"} &middot;
          <time datetime={new Date(frontmatter.pubDate).toISOString()}>
            {new Date(frontmatter.pubDate).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
        </p>
      </div>
    </header>

    {frontmatter.heroImage && (
      <div class="blog-post__hero">
        <div class="container container--narrow">
          <img src={frontmatter.heroImage} alt={frontmatter.title} loading="eager" />
        </div>
      </div>
    )}

    <div class="blog-post__body container container--narrow">
      <slot />
    </div>

    <footer class="blog-post__footer container container--narrow">
      <a href="/blog" class="btn btn--outline">&larr; Back to Blog</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post__header {
    background: var(--color-warm-white);
    padding-block: var(--space-xl);
    text-align: center;
  }
  .blog-post__tags {
    display: flex;
    gap: var(--space-xs);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--space-sm);
  }
  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-caramel);
    background: rgba(193, 130, 57, 0.1);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
  }
  .blog-post__header h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    margin-bottom: var(--space-sm);
  }
  .blog-post__meta {
    font-size: 0.9375rem;
    color: var(--color-chocolate);
    opacity: 0.6;
  }

  .blog-post__hero {
    background: var(--color-cream);
    padding-block: var(--space-md);
  }
  .blog-post__hero img {
    width: 100%;
    border-radius: 8px;
    display: block;
    max-height: 480px;
    object-fit: cover;
  }

  .blog-post__body {
    padding-block: var(--space-xl);
  }
  .blog-post__body :global(h2) {
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }
  .blog-post__body :global(h3) {
    margin-top: var(--space-md);
    margin-bottom: var(--space-xs);
  }
  .blog-post__body :global(p) {
    margin-bottom: var(--space-sm);
    line-height: 1.8;
  }
  .blog-post__body :global(ul),
  .blog-post__body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: var(--space-sm);
  }
  .blog-post__body :global(li) {
    margin-bottom: 0.4rem;
    line-height: 1.7;
  }
  .blog-post__body :global(strong) {
    color: var(--color-chocolate-dark);
  }
  .blog-post__body :global(em) {
    font-style: italic;
  }
  .blog-post__body :global(a) {
    color: var(--color-caramel);
    font-weight: 600;
  }
  .blog-post__body :global(a:hover) {
    text-decoration: underline;
  }
  .blog-post__body :global(hr) {
    border: none;
    border-top: 1px solid rgba(74, 55, 40, 0.15);
    margin-block: var(--space-lg);
  }

  .blog-post__footer {
    padding-bottom: var(--space-xl);
  }
</style>
