---
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description?: string;
  seoType?: "website" | "article" | "product";
  publishDate?: string;
  modifiedDate?: string;
  tags?: string[];
  image?: string;
  productName?: string;
  price?: number;
  availability?: string;
}

const {
  title,
  description = "Sweet Bites by Laura — handcrafted cookies, breads, and cakes made with love.",
  seoType,
  publishDate,
  modifiedDate,
  tags,
  image,
  productName,
  price,
  availability,
} = Astro.props;

const FACEBOOK_URL = "https://www.facebook.com/profile.php?id=61571575571290";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <SEO
    title={title}
    description={description}
    type={seoType}
    publishDate={publishDate}
    modifiedDate={modifiedDate}
    tags={tags}
    image={image}
    productName={productName}
    price={price}
    availability={availability}
  />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:wght@300;400;600&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="site-logo">
        <span class="logo-main">Sweet Bites</span>
        <span class="logo-sub">by Laura</span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/products">Our Treats</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/favorites">Laura's Favorites</a></li>
          <li><a href="/farmstand">Our Farmstand</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
      <a href={FACEBOOK_URL} target="_blank" rel="noopener" class="follow-us-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.413c0-3.026 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.265h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
        </svg>
        Follow Us
      </a>
      <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </header>

  <main><slot /></main>

  <footer class="site-footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <p class="footer-logo">Sweet Bites <em>by Laura</em></p>
        <p class="footer-tagline">Homemade with love, one batch at a time.</p>
        <a href={FACEBOOK_URL} target="_blank" rel="noopener" class="footer-follow">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.413c0-3.026 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.514c-1.491 0-1.956.93-1.956 1.886v2.265h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
          </svg>
          Follow Us on Facebook
        </a>
      </div>
      <nav class="footer-nav">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/products">Our Treats</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/favorites">Laura's Favorites</a></li>
          <li><a href="/farmstand">Our Farmstand</a></li>
          <li><a href="/about">About</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>
      <div class="footer-legal">
        <p>&copy; {new Date().getFullYear()} Sweet Bites by Laura. All rights reserved.</p>
        <p class="affiliate-disclosure">As an Amazon Associate I earn from qualifying purchases.</p>
      </div>
    </div>
  </footer>

  <script>
    const toggle = document.querySelector('.nav-toggle');
    const nav = document.querySelector('.site-nav');
    toggle?.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!expanded));
      nav?.classList.toggle('is-open');
    });
  </script>

</body>
</html>

<style is:global>
  :root {
    --color-chocolate-dark: #2C1A0E;
    --color-chocolate:      #4A3728;
    --color-caramel:        #C18239;
    --color-butter:         #F5E6C8;
    --color-cream:          #FAF6F0;
    --color-warm-white:     #FFFDF9;
    --font-display: 'Playfair Display', Georgia, serif;
    --font-body:    'Source Sans 3', system-ui, sans-serif;
    --space-xs:  0.5rem;
    --space-sm:  1rem;
    --space-md:  1.5rem;
    --space-lg:  2.5rem;
    --space-xl:  4rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-chocolate);
    background: var(--color-warm-white);
  }
  img { max-width: 100%; height: auto; display: block; }
  a { color: inherit; }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-display);
    color: var(--color-chocolate-dark);
    line-height: 1.2;
  }
  h1 { font-size: clamp(2rem, 5vw, 3rem); }
  h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); }
  h3 { font-size: 1.25rem; }

  .container {
    width: 100%;
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: var(--space-md);
    padding-right: var(--space-md);
  }
  .container--narrow { max-width: 760px; }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding: 0.7rem 1.5rem;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: 2px solid transparent;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .btn--primary { background: var(--color-chocolate-dark); color: var(--color-cream); border-color: var(--color-chocolate-dark); }
  .btn--primary:hover { background: var(--color-caramel); border-color: var(--color-caramel); }
  .btn--outline { background: transparent; color: var(--color-chocolate-dark); border-color: var(--color-chocolate-dark); }
  .btn--outline:hover { background: var(--color-chocolate-dark); color: var(--color-cream); }
  .btn--secondary { background: transparent; color: var(--color-caramel); border-color: var(--color-caramel); }
  .btn--secondary:hover { background: var(--color-caramel); color: white; }
  .btn--sm { padding: 0.4rem 0.9rem; font-size: 0.8125rem; }
  .btn--full { width: 100%; justify-content: center; }

  /* Header */
  .site-header {
    background: var(--color-warm-white);
    border-bottom: 1px solid rgba(74,55,40,0.1);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding-top: var(--space-sm);
    padding-bottom: var(--space-sm);
  }
  .site-logo { text-decoration: none; display: flex; flex-direction: column; line-height: 1.1; flex-shrink: 0; }
  .logo-main { font-family: var(--font-display); font-size: 1.375rem; font-weight: 700; color: var(--color-chocolate-dark); }
  .logo-sub { font-family: var(--font-display); font-size: 0.875rem; font-style: italic; color: var(--color-caramel); }
  .site-nav { margin-left: auto; }
  .site-nav ul { display: flex; gap: var(--space-md); list-style: none; }
  .site-nav a { font-size: 0.9375rem; color: var(--color-chocolate); text-decoration: none; font-weight: 600; transition: color 0.2s; }
  .site-nav a:hover { color: var(--color-caramel); }
  .follow-us-link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    background: #1877F2; color: white; font-size: 0.875rem; font-weight: 600;
    padding: 0.4rem 0.9rem; border-radius: 20px; text-decoration: none; flex-shrink: 0; transition: background 0.2s;
  }
  .follow-us-link:hover { background: #1565d8; }
  .nav-toggle { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: 4px; }
  .nav-toggle span { display: block; width: 22px; height: 2px; background: var(--color-chocolate); border-radius: 2px; }

  @media (max-width: 900px) {
    .nav-toggle { display: flex; }
    .follow-us-link { display: none; }
    .site-nav { display: none; position: absolute; top: 100%; left: 0; right: 0; background: var(--color-warm-white); border-bottom: 1px solid rgba(74,55,40,0.1); padding: var(--space-md); }
    .site-nav.is-open { display: block; }
    .site-nav ul { flex-direction: column; gap: var(--space-sm); }
  }

  /* Footer */
  .site-footer { background: var(--color-chocolate-dark); color: var(--color-butter); padding-top: var(--space-xl); padding-bottom: var(--space-xl); }
  .footer-inner { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--space-lg); align-items: start; }
  @media (max-width: 768px) { .footer-inner { grid-template-columns: 1fr; text-align: center; } }
  .footer-logo { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--color-cream); margin-bottom: var(--space-xs); }
  .footer-logo em { font-style: italic; color: var(--color-caramel); }
  .footer-tagline { font-size: 0.9rem; opacity: 0.7; margin-bottom: var(--space-sm); }
  .footer-follow { display: inline-flex; align-items: center; gap: 0.4rem; background: #1877F2; color: white; font-size: 0.875rem; font-weight: 600; padding: 0.4rem 1rem; border-radius: 20px; text-decoration: none; transition: background 0.2s; }
  .footer-follow:hover { background: #1565d8; }
  .footer-nav ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-xs); }
  .footer-nav a { color: var(--color-butter); text-decoration: none; font-size: 0.9375rem; transition: color 0.2s; }
  .footer-nav a:hover { color: var(--color-caramel); }
  .footer-legal { text-align: right; font-size: 0.8125rem; opacity: 0.6; }
  @media (max-width: 768px) { .footer-legal { text-align: center; } }
  .affiliate-disclosure { margin-top: var(--space-xs); font-style: italic; }
</style>
