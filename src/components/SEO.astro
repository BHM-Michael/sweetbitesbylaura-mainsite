---
/**
 * SEO.astro — Reusable SEO component for Sweet Bites by Laura
 *
 * Usage in any page:
 *   import SEO from '../components/SEO.astro';
 *   <SEO title="Page Title" description="Page description" />
 *
 * Props:
 *   title        — Page title (appended with site name)
 *   description  — Meta description (150–160 chars ideal)
 *   image        — OG image URL (absolute). Defaults to site og-image.
 *   url          — Canonical URL. Defaults to current page URL.
 *   type         — OG type: 'website' | 'article' | 'product'. Default 'website'.
 *   noindex      — Set true to block indexing (e.g. draft pages).
 *   schema       — Pass a pre-built JSON-LD object to override the default schema.
 *
 * Optional blog / article props (used when type='article'):
 *   publishDate  — ISO date string, e.g. "2024-06-01"
 *   modifiedDate — ISO date string
 *   author       — Author name string
 *   tags         — string[] of keywords
 *
 * Optional product props (used when type='product'):
 *   productName  — Product name
 *   price        — Price as number
 *   currency     — e.g. "USD"
 *   availability — "InStock" | "OutOfStock" | "PreOrder"
 */

export interface Props {
  title: string;
  description: string;
  image?: string;
  url?: string;
  type?: 'website' | 'article' | 'product';
  noindex?: boolean;
  schema?: Record<string, unknown>;
  // Article props
  publishDate?: string;
  modifiedDate?: string;
  author?: string;
  tags?: string[];
  // Product props
  productName?: string;
  price?: number;
  currency?: string;
  availability?: 'InStock' | 'OutOfStock' | 'PreOrder';
}

const {
  title,
  description,
  image,
  url,
  type = 'website',
  noindex = false,
  schema,
  publishDate,
  modifiedDate,
  author = 'Laura',
  tags = [],
  productName,
  price,
  currency = 'USD',
  availability = 'InStock',
} = Astro.props;

// ─── Site-wide defaults ───────────────────────────────────────────────────────
const SITE_NAME    = 'Sweet Bites by Laura';
const SITE_URL     = 'https://www.sweetbitesbylaura.com'; // ← update to your domain
const SITE_LOCALE  = 'en_US';
const TWITTER_HANDLE = '@sweetbitesbylaura'; // ← update or remove if not on X/Twitter
const DEFAULT_OG_IMAGE = `${SITE_URL}/images/og-default.jpg`; // ← ensure this file exists

// ─── Resolved values ─────────────────────────────────────────────────────────
const pageTitle    = `${title} | ${SITE_NAME}`;
const canonicalURL = url ?? new URL(Astro.url.pathname, SITE_URL).href;
const ogImage      = image ?? DEFAULT_OG_IMAGE;

// ─── Structured data (JSON-LD) ────────────────────────────────────────────────
let jsonLd: Record<string, unknown>;

if (schema) {
  // Caller provided a custom schema — use it as-is
  jsonLd = schema;
} else if (type === 'article') {
  jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: ogImage,
    url: canonicalURL,
    datePublished: publishDate,
    dateModified: modifiedDate ?? publishDate,
    author: {
      '@type': 'Person',
      name: author,
    },
    publisher: {
      '@type': 'Organization',
      name: SITE_NAME,
      url: SITE_URL,
      logo: {
        '@type': 'ImageObject',
        url: `${SITE_URL}/images/logo.png`,
      },
    },
    keywords: tags.join(', '),
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': canonicalURL,
    },
  };
} else if (type === 'product') {
  jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: productName ?? title,
    description,
    image: ogImage,
    url: canonicalURL,
    brand: {
      '@type': 'Brand',
      name: SITE_NAME,
    },
    ...(price !== undefined && {
      offers: {
        '@type': 'Offer',
        priceCurrency: currency,
        price: price.toFixed(2),
        availability: `https://schema.org/${availability}`,
        url: canonicalURL,
      },
    }),
  };
} else {
  // Default: LocalBusiness / Bakery schema for home / about / general pages
  jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Bakery',
    name: SITE_NAME,
    url: SITE_URL,
    image: ogImage,
    description,
    priceRange: '$$',
    servesCuisine: ['Cookies', 'Candy', 'Baked Goods'],
    sameAs: [
      // Add your social profile URLs here, e.g.:
      // 'https://www.instagram.com/sweetbitesbylaura',
      // 'https://www.facebook.com/sweetbitesbylaura',
    ],
  };
}
---

<!-- ═══ Primary meta ════════════════════════════════════════════════════════ -->
<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}

<!-- ═══ Open Graph ══════════════════════════════════════════════════════════ -->
<meta property="og:title"       content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url"         content={canonicalURL} />
<meta property="og:site_name"   content={SITE_NAME} />
<meta property="og:locale"      content={SITE_LOCALE} />
<meta property="og:image"       content={ogImage} />
<meta property="og:image:width"  content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt"    content={`${SITE_NAME} — ${title}`} />
<meta property="og:type"        content={type === 'article' ? 'article' : 'website'} />

{type === 'article' && publishDate && (
  <meta property="article:published_time" content={publishDate} />
)}
{type === 'article' && modifiedDate && (
  <meta property="article:modified_time" content={modifiedDate} />
)}
{type === 'article' && tags.map((tag) => (
  <meta property="article:tag" content={tag} />
))}

<!-- ═══ Twitter / X Card ════════════════════════════════════════════════════ -->
<meta name="twitter:card"        content="summary_large_image" />
<meta name="twitter:title"       content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image"       content={ogImage} />
<meta name="twitter:image:alt"   content={`${SITE_NAME} — ${title}`} />
{TWITTER_HANDLE && <meta name="twitter:site" content={TWITTER_HANDLE} />}

<!-- ═══ Structured data (JSON-LD) ══════════════════════════════════════════ -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd, null, 2)} />
